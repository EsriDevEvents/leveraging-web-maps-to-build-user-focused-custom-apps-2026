<Window
    x:Class="DevSummit2026.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
    xmlns:toolkit="http://schemas.esri.com/arcgis/runtime/2013"
    Title="DevSummit2026"
    Width="1200"
    Height="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <esri:MapView x:Name="_mapView" />

            <Border
                x:Name="_popupPanel"
                Width="420"
                Height="Auto"
                Margin="12"
                Padding="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#CCFFFFFF"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">

                <toolkit:PopupViewer x:Name="_popupViewer" MaxHeight="800" />
            </Border>

        </Grid>

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <DockPanel LastChildFill="False">

                <StackPanel
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    Orientation="Horizontal">
                    <Button
                        x:Name="_playPauseButton"
                        Width="110"
                        Margin="0,0,12,0"
                        Click="PlayPause_Click"
                        Content="Play" />

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="Speed" />

                    <Slider
                        x:Name="_speedSlider"
                        Width="220"
                        IsSnapToTickEnabled="True"
                        Maximum="4.0"
                        Minimum="0.25"
                        TickFrequency="0.25"
                        ValueChanged="SpeedSlider_ValueChanged"
                        Value="1.0" />

                    <TextBlock
                        x:Name="_speedText"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Text="1.0x" />
                </StackPanel>

                <Separator Width="1" Margin="18,0" />

                <StackPanel
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <ToggleButton
                        x:Name="_captureToggle"
                        Width="140"
                        Checked="Capture_Checked"
                        Content="Capture mode"
                        Unchecked="Capture_Unchecked" />

                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Text="Points:" />

                    <TextBlock
                        x:Name="_captureCountText"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="0" />
                </StackPanel>

            </DockPanel>
        </Border>

    </Grid>
</Window>